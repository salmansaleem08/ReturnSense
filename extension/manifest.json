{
  "manifest_version": 3,
  "name": "ReturnSense",
  "version": "1.0.1",
  "description": "AI buyer risk analysis for Instagram sellers",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://m.instagram.com/*",
    "https://return-sense-web.vercel.app/*",
    "https://*.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": [
      "https://www.instagram.com/*",
      "https://instagram.com/*",
      "https://m.instagram.com/*"
    ],
    "js": ["content.js"],
    "css": ["styles.css"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  }
}
