NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Production dashboard & extension deep links (must match your Vercel URL if not using default)
NEXT_PUBLIC_APP_URL=https://return-sense-web.vercel.app

# Google Gemini (optional — falls back to OpenRouter if missing or model errors)
# GEMINI_API_KEY=
# Default model is gemini-2.0-flash; override if Google renames models:
# GEMINI_MODEL=gemini-2.0-flash

# Abstract Phone Validation — key must be from Phone Validation API product (401 = wrong key/product)
# ABSTRACT_API_KEY=
