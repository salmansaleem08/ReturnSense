NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Production dashboard & extension deep links (must match your Vercel URL if not using default)
NEXT_PUBLIC_APP_URL=https://return-sense-web.vercel.app

# OpenRouter (required for parallel tri-model trust engine — behavior / commitment / fraud)
# OPENROUTER_API_KEY=
# Set RS_USE_TRI_ENGINE=false to force legacy single-model Gemini/OpenRouter rubric
# RS_USE_TRI_ENGINE=
# RS_TRI_MODEL_BEHAVIOR=mistralai/mistral-small-3.1-24b-instruct:free
# RS_TRI_MODEL_COMMITMENT=deepseek/deepseek-chat
# RS_TRI_MODEL_FRAUD=deepseek/deepseek-chat

# Google Gemini (optional — used only when tri-engine fails or is disabled)
# GEMINI_API_KEY=
# Default: gemini-2.5-flash (2.0-flash may be unavailable for new API keys)
# GEMINI_MODEL=gemini-2.5-flash

# Abstract — use the key from the SAME API product as the host below:
# ABSTRACT_API_KEY=
# Default host is Phone Intelligence. Legacy Phone Validation:
# ABSTRACT_PHONE_API_URL=https://phonevalidation.abstractapi.com/v1
