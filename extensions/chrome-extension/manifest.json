{
  "manifest_version": 3,
  "name": "ReturnSense Companion",
  "version": "0.1.0",
  "description": "ReturnSense browser companion extension.",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "ReturnSense"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:8000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
